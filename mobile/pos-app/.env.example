# Backend base URL (no trailing slash). Wrong URL → "Network request failed".
#
# Android EMULATOR (on your Mac/PC): MUST use host loopback alias — NOT 127.0.0.1
#   EXPO_PUBLIC_API_URL=http://10.0.2.2:8000
# iOS simulator: http://127.0.0.1:8000
# Physical phone + Expo Go: same Wi‑Fi as computer, use computer LAN IP
#   EXPO_PUBLIC_API_URL=http://192.168.x.x:8000
#
# Run backend bound to all interfaces:  uvicorn app.main:app --host 0.0.0.0 --port 8000
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000

# Optional: pin a single shop UUID (from GET /stores)
EXPO_PUBLIC_STORE_ID=

# Optional: paste a Clerk *session* JWT for debugging only (three parts: xxxx.yyyy.zzzz).
# NEVER put the publishable key (pk_test_ / pk_live_) here — that is NOT a JWT.
EXPO_PUBLIC_AUTH_TOKEN=

# Clerk (same instance as backend CLERK_ISSUER / JWKS). When set, app shows sign-in and sends session JWT.
# Dashboard → API Keys → Publishable key
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Clerk Dashboard → Native applications → add redirect URL shown on the sign-in screen
# (must match app.json "scheme", e.g. garments-pos://)

# Dev: log bearer in Metro — default truncated; set to 1 for full JWT (unsafe to share)
# EXPO_PUBLIC_LOG_FULL_BEARER=
