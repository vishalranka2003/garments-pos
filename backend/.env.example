APP_NAME=Garments POS API
APP_ENV=development
# When true: truncated Bearer preview + GET/POST /stores logs (count, ids, names).
APP_DEBUG=true
AUTO_CREATE_TABLES=false

# Supabase Postgres URL (transaction/pooler URL recommended)
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR_PASSWORD]@[YOUR_HOST]:6543/postgres?sslmode=require

# Clerk JWT validation — use the SAME instance as EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY on the app.
# Dashboard → Configure → API keys → copy "Frontend API URL" (ends with .clerk.accounts.dev for dev).
# Common mistake: https://INSTANCE.accounts.dev/... (404) — correct: https://INSTANCE.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=https://YOUR_INSTANCE.clerk.accounts.dev/.well-known/jwks.json
# Issuer is usually the same origin as Frontend API (JWT "iss" claim); copy from Clerk or JWT debugger.
CLERK_ISSUER=https://YOUR_INSTANCE.clerk.accounts.dev
CLERK_AUDIENCE=
# Local dev without mobile JWT: AUTH_BYPASS=true and APP_ENV=development (see app/core/auth.py)
AUTH_BYPASS=false
AUTH_BYPASS_USER_ID=dev_user_001

# Set true only if you intentionally want to allow below-zero inventory
ALLOW_NEGATIVE_STOCK=false
